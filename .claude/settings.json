{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "PowerShell(git status)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "PowerShell(git push *)",
      "PowerShell(rm *)",
      "PowerShell(Remove-Item *)"
    ],
    "deny": [
      "Read(./.env)",
      "Edit(./.env)"
    ]
  }
}
