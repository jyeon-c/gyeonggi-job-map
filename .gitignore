# === 민감 정보 / 환경설정 ===
.env
.env.*
!.env.example
application-local.yml
application-local.yaml
**/src/main/resources/application-secret.yml
# SSH 키 등 인증서 — 절대 커밋 금지
*.pem

# === 원본 데이터 (개인정보 포함 가능, 절대 커밋 금지) ===
data/raw/

# === Gradle ===
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# === IntelliJ ===
.idea/
*.iml
out/

# === OS ===
.DS_Store
Thumbs.db

# === 로그 ===
*.log
logs/

# === Obsidian (개인 설정만 제외, 노트 자체는 커밋됨) ===
.obsidian/workspace*
.obsidian/plugins/*/data.json

# === Docker 관련 로컬 볼륨 (필요 시) ===
infra/postgres-data/

# === 데이터 파이프라인 파생 산출물 ===
# 디렉터리 자체가 아니라 내용물(*)을 무시해야 아래 jobs.json 예외가 동작한다.
data/processed/*
# 단, jobs.json 은 배포 시드 데이터(백엔드 이미지에 포함)라 커밋한다. 캐시 등은 제외.
!data/processed/jobs.json

# === 프런트 로컬 설정 (apply-env.ps1 생성) ===
frontend/js/config.js
