# 환경변수 템플릿 — 실제 값은 .env 에 넣는다(.env 는 gitignore/커밋 금지).
# 로컬: cp .env.example .env  후 값 채우고  scripts/apply-env.ps1 실행
# 운영(EC2): 이 값들로 .env 작성 후  docker compose up -d --build

# --- 카카오맵 (프런트 SDK) ---
# 개발자 콘솔 > 앱 > 앱 키 > JavaScript 키. [플랫폼 > Web]에 도메인 등록 필수.
KAKAO_JS_KEY=여기에_카카오_JS_키

# --- 카카오 지오코딩 (선택, 배치용) ---
# REST API 키. 설정 시 scripts/build-jobs-data.ps1 이 주소→좌표 정밀 변환.
# KAKAO_REST_API_KEY=

# --- 프런트 API 오리진 (로컬 개발 전용) ---
# 로컬은 백엔드가 8080. 비워두면 apply-env.ps1 이 http://localhost:8080 을 기본 사용.
# 운영은 nginx 가 같은 오리진에서 /api 프록시하므로 이 값과 무관(compose 가 API_BASE="" 주입).
# API_BASE=http://localhost:8080

# --- 데이터베이스 (운영 docker compose) ---
DB_NAME=jobmap
DB_USERNAME=jobmap
DB_PASSWORD=여기에_강력한_비밀번호
